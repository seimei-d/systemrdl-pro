{
  "addrmap": {
    "prefix": "addrmap",
    "body": [
      "addrmap ${1:name} {",
      "\tname = \"${2:Display name}\";",
      "\tdesc = \"${3:Description.}\";",
      "\t$0",
      "};"
    ],
    "description": "Top-level addrmap with name/desc."
  },
  "regfile": {
    "prefix": "regfile",
    "body": [
      "regfile ${1:type_name} {",
      "\t$0",
      "} ${2:inst_name} @ ${3:0x0};"
    ],
    "description": "Regfile type + instance."
  },
  "reg": {
    "prefix": "reg",
    "body": [
      "reg {",
      "\tname = \"${1:Display name}\";",
      "\tdesc = \"${2:Description.}\";",
      "\tfield { sw=${3|rw,ro,wo,r,w|}; hw=${4|r,w,rw|}; } ${5:field_name}[${6:0}:${7:0}] = ${8:0};",
      "} ${9:REG_NAME} @ ${10:0x0};"
    ],
    "description": "Register instance with one field, name, desc."
  },
  "reg-typed": {
    "prefix": "regtyped",
    "body": [
      "reg ${1:type_name} {",
      "\tname = \"${2:Display name}\";",
      "\tfield { sw=${3|rw,ro,wo|}; hw=${4|r,w,rw|}; } ${5:field}[${6:0}:${7:0}] = ${8:0};",
      "\t$0",
      "};"
    ],
    "description": "Named register type — instantiate later as `type_name FOO @ 0xN;`."
  },
  "field": {
    "prefix": "field",
    "body": [
      "field { sw=${1|rw,ro,wo,r,w|}; hw=${2|r,w,rw|}; } ${3:name}[${4:0}:${5:0}] = ${6:0};"
    ],
    "description": "Single bit/range field with sw + hw access."
  },
  "field-w1c": {
    "prefix": "fieldw1c",
    "body": [
      "field {",
      "\tsw=w; hw=r;",
      "\tonwrite = woclr;",
      "\tdesc = \"${1:Description}\";",
      "} ${2:name}[${3:0}:${4:0}] = 0;"
    ],
    "description": "Write-1-to-clear status field."
  },
  "field-counter": {
    "prefix": "fieldcounter",
    "body": [
      "field {",
      "\tsw=r; hw=rw;",
      "\tcounter = true;",
      "\tincrwidth = ${1:1};",
      "} ${2:name}[${3:31}:${4:0}] = 0;"
    ],
    "description": "Hardware counter field."
  },
  "include": {
    "prefix": "include",
    "body": "`include \"${1:path/to/file.rdl}\"",
    "description": "Verilog-style `include directive."
  },
  "perl-loop": {
    "prefix": "perlloop",
    "body": [
      "<% for my \\$i (0..${1:3}) { %>",
      "\t${2:type_t} ${3:R}_<%=\\$i%> @ <%=\\$i*${4:4}%>;",
      "<% } %>"
    ],
    "description": "Perl preprocessor loop generating N register instances."
  }
}
